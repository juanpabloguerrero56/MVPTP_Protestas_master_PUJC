##------CONJUNTOS
set D := D1 D2 D3 D4;
set K := 1 2;

set I := F1 F2 F3 F4 F5 F6 F7 F8;

# F1 -> Excel 810, Comuna 8
# F2 -> Excel 806, Comuna 8
# F3 -> Excel 814, Comuna 8
# F4 -> Excel 1696, Comuna 16
# F5 -> Excel 1605, Comuna 16
# F6 -> Excel 1303, Comuna 13
# F7 -> Excel 1302, Comuna 13
# F8 -> Excel 1310, Comuna 13

# Clústeres
